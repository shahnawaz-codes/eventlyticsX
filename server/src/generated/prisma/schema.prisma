generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id         String   @id @default(uuid())
  eventType  String
  path       String
  projectKey String
  sessionId  String
  referrer   String
  createdAt  DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
