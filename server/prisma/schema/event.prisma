model Event {
  id         String   @id @default(uuid())
  eventType  String
  path       String
  projectKey String
  project    Project  @relation(fields: [projectKey], references: [public_key])
  sessionId  String
  referrer   String
  browser    String
  os         String
  device     String
  country    String
  city       String?
  region     String?
  createdAt  DateTime @default(now())
}
